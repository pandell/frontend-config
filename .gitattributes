# spell-checker:words gitattr asax ashx bmml datasource rdlc resx slnx xlsb

# Set default behavior, use UNIX-style newlines everywhere (Windows, Linux, macOS).
*             text eol=lf

# Text files that should be normalized (convert crlf => lf)
# (see https://github.com/git/git/blob/master/userdiff.c for a list of diff drivers available in Git for Windows)
.gitignore    text
.gitattr*     text
*.asax        text
*.ascx        text
*.ashx        text
*.aspx        text
*.bmml        text
*.cd          text
*.cmd         text
*.config      text
*.cs          text diff=csharp
*.cshtml      text
*.csproj      text
*.css         text
*.datasource  text
*.fs          text
*.fsproj      text
*.htc         text
*.htm         text diff=html
*.html        text diff=html
*.js          text
*.jsx         text
*.json        text
*.jsonc       text
*.kt          text diff=kotlin
*.kts         text diff=kotlin
*.Master      text
*.md          text diff=markdown
*.mrt         text
*.proj        text
*.ps1         text
*.rdlc        text
*.resx        text
*.settings    text
*.sln         text
*.slnx        text
*.sql         text
*.targets     text
*.ts          text
*.tsx         text
*.tt          text
*.txt         text
*.vbs         text
*.xml         text
*.xsd         text
*.xslt        text

# Text files with forced crlf
*.bat         text eol=crlf
*.cmd         text eol=crlf

# Binary files (left alone)
*.bmp         binary
*.dll         binary
*.exe         binary
*.gif         binary
*.ico         binary
*.jpg         binary
*.mdf         binary
*.png         binary
*.psd         binary
*.snk         binary
*.vsd         binary
*.xlsb        binary
*.xlsx        binary
